---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/intro.jpg';
---

<section class="relative min-h-[calc(100dvh-4rem)] flex items-center">
  <div class="grid w-full lg:grid-cols-2">
    <!-- Left panel: text -->
    <div class="flex items-center px-8 py-20 sm:px-16 lg:px-20 xl:px-28">
      <div class="max-w-lg">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-accent)]">Research Project</p>
        <h1 class="mt-4 text-5xl font-bold leading-[1.1] tracking-tight sm:text-6xl lg:text-7xl">
          QUARTZ
        </h1>
        <p class="mt-3 text-xl text-[var(--color-text-muted)]">
          Machine Driven Glass Fabrication
        </p>
        <p class="mt-6 text-base leading-relaxed text-[var(--color-text-muted)]">
          A material research project uniting computer-aided rapid prototyping
          technology with glass — one of the most versatile design materials.
        </p>
        <div class="mt-10 flex gap-4">
          <a
            href="/quartz/docs/01-introduction"
            class="inline-block rounded-md bg-[var(--color-accent)] px-7 py-3 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-accent-hover)]"
          >
            Get Started
          </a>
          <a
            href="/quartz/docs/02-experiments"
            class="inline-block rounded-md border border-[var(--color-border)] px-7 py-3 text-sm font-semibold text-[var(--color-text)] transition-colors hover:bg-[var(--color-bg-surface)]"
          >
            View Experiments
          </a>
        </div>
      </div>
    </div>
    <!-- Right panel: image -->
    <div class="relative hidden lg:block">
      <div class="absolute inset-0 bg-[var(--color-bg-surface)]">
        <Image
          src={heroImage}
          alt="CAD model of the glass extrusion machine"
          class="h-full w-full object-cover"
          widths={[720, 960, 1280]}
          sizes="50vw"
        />
      </div>
    </div>
  </div>
</section>
